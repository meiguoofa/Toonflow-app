# Toonflow 客户端构建期配置模板
# 本机构建时：cp env/.env.production.example env/.env.production 并填值，
# 然后在构建前导入到环境变量（见 docs/build-release.md）。
# CI 构建走 GitHub Variables/Secrets，不需要此文件。
# 真实文件 env/.env.production 已在 .gitignore 中，不会提交。

# 生产后端地址（云服务器 IP，无域名）。示例：
TOONFLOW_BACKEND_URL=http://SERVER_IP:4000

# 与后端 .env 中完全一致的 JWT 密钥（openssl rand -hex 32）。
# 注意：该值会被烧进安装包，理论上可被提取——内部工具可接受。
JWT_SECRET=must_match_backend_jwt_secret
